# ===== MySQL 数据库 =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_interview
DB_USER=root
DB_PASSWORD=your_db_password_here

# ===== MySQL 连接池（Sequelize pool）=====
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=10000
DB_POOL_IDLE=10000
DB_POOL_EVICT=5000

# ===== JWT 鉴权 =====
# 请使用足够长的随机字符串（建议 32 位以上）
JWT_SECRET=please_change_to_a_long_random_string

# ===== 服务依赖 =====
AI_SERVICE_URL=http://localhost:8000
REDIS_HOST=localhost
REDIS_PORT=6379