# ===== 阿里云通义千问 / DashScope =====
# 在 https://dashscope.console.aliyun.com/ 申请 API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_MAX_MODEL=qwen-max
QWEN_PLUS_MODEL=qwen-plus-0112
QWEN_TURBO_MODEL=qwen-turbo

# ===== OCR 配置 =====
OCR_LANG=ch
PADDLEOCR_HOME=.paddleocr

# ===== MySQL 数据库 =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_interview
DB_USER=root
DB_PASSWORD=your_db_password_here

# ===== MySQL 连接池（DBUtils.PooledDB）=====
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_MAX_IDLE=5
DB_CONNECT_TIMEOUT=10

# ===== RAG / 向量检索 =====
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=interview_questions
QUESTION_BANK_DIR=./question_bank
RAG_TOP_K=7
LLM_QUESTIONS_COUNT=1
RAG_SCORE_THRESHOLD=0.25